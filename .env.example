# ============ STRIPE ============
# Récupère ces clés sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============ SITE ============
PUBLIC_SITE_URL=http://localhost:4321

# ============ FIREBASE (CLIENT) ============
# Console Firebase → Paramètres du projet → Vos applications
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ============ FIREBASE ADMIN (SERVEUR) ============
# Pour écrire les commandes dans Firestore depuis le webhook.
# Génère un service account : Console → ⚙️ Paramètres → Comptes de service
# → "Générer une nouvelle clé privée" → ouvre le JSON et reporte les 3 valeurs :
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@nayab-market.iam.gserviceaccount.com
# IMPORTANT : remplacer chaque vrai saut de ligne du PEM par "\n" littéral.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============ EMAILS (RESEND) ============
# https://resend.com/api-keys (gratuit, 100 mails/jour)
RESEND_API_KEY=re_...
# Domaine d'envoi vérifié dans Resend. Tant qu'aucun domaine n'est vérifié,
# tu ne peux envoyer que depuis "onboarding@resend.dev" vers l'email du compte Resend.
RESEND_FROM_EMAIL="Nayab Market <onboarding@resend.dev>"
# Email du gérant pour recevoir les notifications de nouvelles commandes
ADMIN_NOTIFICATION_EMAIL=gerant@nayabmarket.fr
