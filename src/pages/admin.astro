---
import Layout from '~/layouts/Layout.astro';
import AdminNav from '~/components/AdminNav.astro';
import { categories } from '~/lib/products';

export const prerender = false;
---

<Layout title="Admin · Produits — Nayab Market" description="Espace de gestion des produits" noindex={true}>
  <section class="py-12 px-4 sm:px-6 bg-gradient-to-br from-lapis-900 via-lapis-800 to-pomegranate-900 text-sand-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-kilim-pattern opacity-50"></div>
    <div class="relative z-10 max-w-7xl mx-auto text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-saffron-300 mb-2">Espace Gérant</h1>
      <p class="font-accent text-lg text-sand-100 italic">Gestion du catalogue produits</p>
    </div>
  </section>

  <AdminNav />

  <section class="py-12 px-4 sm:px-6 bg-sand-50 min-h-[70vh]">
    <div class="max-w-7xl mx-auto">
      <!-- État: Firebase non configuré -->
      <div id="not-configured" class="hidden max-w-2xl mx-auto bg-white border-2 border-saffron-300 rounded-2xl p-8 shadow-lg">
        <h2 class="font-display text-2xl text-lapis-900 mb-3">⚙️ Firebase non configuré</h2>
        <p class="text-lapis-700 mb-4">
          Pour activer l'espace admin, configure Firebase dans le fichier <code class="bg-sand-100 px-2 py-0.5 rounded">.env</code> :
        </p>
        <pre class="bg-lapis-900 text-saffron-300 p-4 rounded-lg text-sm overflow-x-auto"><code>PUBLIC_FIREBASE_API_KEY=...
PUBLIC_FIREBASE_AUTH_DOMAIN=...
PUBLIC_FIREBASE_PROJECT_ID=...
PUBLIC_FIREBASE_STORAGE_BUCKET=...
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
PUBLIC_FIREBASE_APP_ID=...</code></pre>
        <p class="text-sm text-lapis-600 mt-4">
          Voir <a href="/README.md" class="text-pomegranate-700 underline">README</a> pour les instructions complètes.
        </p>
      </div>

      <!-- État: Connecté mais pas admin -->
      <div id="not-admin" class="hidden max-w-md mx-auto bg-white border-2 border-pomegranate-300 rounded-2xl p-8 shadow-lg text-center">
        <h2 class="font-display text-xl text-pomegranate-700 mb-2">Accès refusé</h2>
        <p class="text-lapis-700 mb-4">Votre compte n'a pas les droits d'administrateur.</p>
        <div class="flex gap-2 justify-center">
          <a href="/compte" class="px-5 py-2 bg-lapis-900 text-saffron-300 rounded-full font-semibold text-sm hover:bg-lapis-800 transition">Mon compte</a>
          <button id="not-admin-logout" class="px-5 py-2 border-2 border-pomegranate-600 text-pomegranate-700 rounded-full font-semibold text-sm hover:bg-pomegranate-600 hover:text-white transition">Déconnexion</button>
        </div>
      </div>

      <!-- État: Non connecté -->
      <div id="login-section" class="hidden max-w-md mx-auto">
        <div class="bg-white border-2 border-saffron-200 rounded-2xl p-8 shadow-lg">
          <h2 class="font-display text-2xl text-lapis-900 mb-6 text-center">Connexion</h2>
          <form id="login-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-semibold text-lapis-900 mb-1">Email</label>
              <input
                type="email"
                id="email"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-semibold text-lapis-900 mb-1">Mot de passe</label>
              <input
                type="password"
                id="password"
                required
                autocomplete="current-password"
                class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition"
              />
            </div>
            <p id="login-error" class="text-pomegranate-700 text-sm min-h-[1.25rem]"></p>
            <button
              type="submit"
              class="w-full px-6 py-3 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition-all"
            >
              Se connecter
            </button>
          </form>
        </div>
      </div>

      <!-- État: Connecté — Admin -->
      <div id="admin-section" class="hidden">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 bg-white rounded-2xl p-5 border-2 border-saffron-200 shadow-md">
          <div>
            <div class="text-sm text-lapis-600">Connecté en tant que</div>
            <div id="user-email" class="font-semibold text-lapis-900"></div>
          </div>
          <div class="flex gap-3">
            <button
              id="add-btn"
              class="px-5 py-2.5 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold text-sm hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition"
            >
              + Ajouter un produit
            </button>
            <button
              id="seed-btn"
              class="px-5 py-2.5 border-2 border-lapis-900 text-lapis-900 rounded-full font-semibold text-sm hover:bg-lapis-900 hover:text-saffron-300 transition"
              title="Importer products.json dans Firestore"
            >
              Importer le seed
            </button>
            <button
              id="logout-btn"
              class="px-5 py-2.5 border-2 border-pomegranate-600 text-pomegranate-700 rounded-full font-semibold text-sm hover:bg-pomegranate-600 hover:text-white transition"
            >
              Déconnexion
            </button>
          </div>
        </div>

        <div id="product-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <p class="col-span-full text-center text-lapis-600 italic py-12">Chargement…</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal ajout/édition -->
  <div
    id="product-modal"
    class="hidden fixed inset-0 z-[2000] bg-lapis-900/75 backdrop-blur-sm items-center justify-center p-4"
  >
    <div class="bg-white rounded-2xl p-6 sm:p-8 w-full max-w-lg max-h-[92vh] overflow-y-auto border-t-4 border-saffron-500 relative">
      <button id="close-modal" class="absolute top-3 right-4 text-3xl text-lapis-500 hover:text-pomegranate-700 leading-none" aria-label="Fermer">×</button>
      <h3 id="modal-title" class="font-display text-2xl text-lapis-900 mb-5">Ajouter un produit</h3>

      <form id="product-form" class="space-y-3">
        <div>
          <label class="block text-sm font-semibold text-lapis-900 mb-1">Nom *</label>
          <input type="text" id="f-name" required maxlength="80" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-lapis-900 mb-1">Slug (URL)</label>
          <input type="text" id="f-slug" maxlength="80" placeholder="pistaches-kerman" pattern="[a-z0-9-]+" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white font-mono text-sm" />
          <p class="text-xs text-lapis-500 mt-1">Auto-généré si vide. Minuscules, chiffres, tirets.</p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1">Catégorie *</label>
            <select id="f-category" required class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white">
              {categories.map((c) => <option value={c.id}>{c.emoji} {c.name}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1">Unité *</label>
            <input type="text" id="f-unit" required maxlength="20" placeholder="250 g" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1">Prix (€) *</label>
            <input type="number" id="f-price" required step="0.01" min="0" placeholder="14.90" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1">Stock *</label>
            <input type="number" id="f-stock" required step="1" min="0" value="0" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-lapis-900 mb-1">Description courte *</label>
          <input type="text" id="f-short" required maxlength="160" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-lapis-900 mb-1">Description complète *</label>
          <textarea id="f-desc" required rows="3" maxlength="500" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white"></textarea>
        </div>

        <div>
          <label class="block text-sm font-semibold text-lapis-900 mb-1">Image</label>
          <input type="file" id="f-image" accept="image/*" class="w-full px-3 py-2 border border-sand-300 rounded-lg bg-sand-50 text-sm" />
          <img id="f-image-preview" class="hidden mt-2 max-h-48 rounded-lg bg-sand-100" alt="Aperçu" />
          <p class="text-xs text-lapis-500 mt-1">L'image est redimensionnée (max 1000px) et stockée dans Firestore.</p>
        </div>

        <p id="form-error" class="text-pomegranate-700 text-sm min-h-[1.25rem]"></p>

        <div class="flex gap-3 justify-end flex-wrap pt-2">
          <button type="button" id="delete-btn" class="hidden mr-auto px-5 py-2 bg-pomegranate-700 text-white rounded-full font-semibold text-sm hover:bg-pomegranate-800 transition">
            Supprimer
          </button>
          <button type="button" id="cancel-btn" class="px-5 py-2 border border-sand-400 text-lapis-900 rounded-full font-semibold text-sm hover:bg-sand-100 transition">
            Annuler
          </button>
          <button type="submit" id="submit-btn" class="px-5 py-2 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold text-sm hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition-all disabled:opacity-60">
            Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { initializeApp, type FirebaseApp } from 'firebase/app';
  import {
    getAuth,
    signInWithEmailAndPassword,
    signOut,
    onAuthStateChanged,
    type Auth,
  } from 'firebase/auth';
  import {
    getFirestore,
    collection,
    onSnapshot,
    addDoc,
    setDoc,
    updateDoc,
    deleteDoc,
    doc,
    getDoc,
    serverTimestamp,
    query,
    orderBy,
    type Firestore,
  } from 'firebase/firestore';

  // Seed local (importé depuis products.json) — pour le bouton "Importer le seed"
  const seedData = (await import('~/data/products.json')).default;

  const config = {
    apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
    authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
    projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
    storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
    messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
    appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
  };

  const notConfigured = document.getElementById('not-configured')!;
  const loginSection = document.getElementById('login-section')!;
  const adminSection = document.getElementById('admin-section')!;
  const productList = document.getElementById('product-list')!;
  const modal = document.getElementById('product-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const form = document.getElementById('product-form') as HTMLFormElement;
  const formError = document.getElementById('form-error')!;
  const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const imageInput = document.getElementById('f-image') as HTMLInputElement;
  const imagePreview = document.getElementById('f-image-preview') as HTMLImageElement;

  const fName = document.getElementById('f-name') as HTMLInputElement;
  const fSlug = document.getElementById('f-slug') as HTMLInputElement;
  const fCategory = document.getElementById('f-category') as HTMLSelectElement;
  const fUnit = document.getElementById('f-unit') as HTMLInputElement;
  const fPrice = document.getElementById('f-price') as HTMLInputElement;
  const fStock = document.getElementById('f-stock') as HTMLInputElement;
  const fShort = document.getElementById('f-short') as HTMLInputElement;
  const fDesc = document.getElementById('f-desc') as HTMLTextAreaElement;

  type Product = {
    id: string;
    slug: string;
    name: string;
    category: string;
    description: string;
    shortDescription: string;
    priceCents: number;
    currency: string;
    unit: string;
    image: string;
    stock: number;
  };

  let app: FirebaseApp | null = null;
  let auth: Auth | null = null;
  let db: Firestore | null = null;
  let products: Product[] = [];
  let editingId: string | null = null;
  let currentImage = '';

  function escapeHtml(s: string) {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function slugify(s: string) {
    return s
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  function formatPrice(cents: number) {
    return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(cents / 100);
  }

  function showModal(show: boolean) {
    modal.classList.toggle('hidden', !show);
    modal.classList.toggle('flex', show);
  }

  function resetForm() {
    editingId = null;
    currentImage = '';
    form.reset();
    imagePreview.classList.add('hidden');
    imagePreview.src = '';
    deleteBtn.classList.add('hidden');
    formError.textContent = '';
    modalTitle.textContent = 'Ajouter un produit';
  }

  function fillForm(p: Product) {
    editingId = p.id;
    currentImage = p.image;
    fName.value = p.name;
    fSlug.value = p.slug;
    fCategory.value = p.category;
    fUnit.value = p.unit;
    fPrice.value = (p.priceCents / 100).toFixed(2);
    fStock.value = String(p.stock);
    fShort.value = p.shortDescription;
    fDesc.value = p.description;
    if (p.image) {
      imagePreview.src = p.image;
      imagePreview.classList.remove('hidden');
    }
    deleteBtn.classList.remove('hidden');
    modalTitle.textContent = 'Modifier le produit';
    formError.textContent = '';
  }

  function renderProducts() {
    if (!products.length) {
      productList.innerHTML = `<div class="col-span-full text-center py-16">
        <p class="text-lapis-600 italic mb-4">Aucun produit dans Firestore.</p>
        <p class="text-lapis-700 text-sm">Clique sur "Importer le seed" pour ajouter les 12 produits de démo, ou "+ Ajouter" pour en créer un.</p>
      </div>`;
      return;
    }
    productList.innerHTML = products
      .map(
        (p) => `
        <div class="bg-white rounded-2xl overflow-hidden border-2 border-saffron-200 shadow-md hover:shadow-xl hover:border-saffron-400 transition-all">
          <div class="aspect-square overflow-hidden bg-sand-100 relative">
            <img src="${escapeHtml(p.image || '')}" alt="${escapeHtml(p.name)}" class="w-full h-full object-cover" />
            <span class="absolute top-2 left-2 px-2 py-0.5 bg-lapis-900/85 text-saffron-300 text-xs rounded-full">${escapeHtml(p.category)}</span>
            <span class="absolute top-2 right-2 px-2 py-0.5 bg-white/95 text-lapis-900 text-xs rounded-full font-semibold">Stock: ${p.stock}</span>
          </div>
          <div class="p-4">
            <h3 class="font-display text-base font-semibold text-lapis-900 mb-1 line-clamp-1">${escapeHtml(p.name)}</h3>
            <p class="text-xs text-lapis-600 mb-2 line-clamp-2">${escapeHtml(p.shortDescription)}</p>
            <div class="flex items-baseline justify-between mb-3">
              <span class="font-accent text-xl font-bold text-pomegranate-700">${formatPrice(p.priceCents)}</span>
              <span class="text-xs text-lapis-500">/ ${escapeHtml(p.unit)}</span>
            </div>
            <button data-id="${escapeHtml(p.id)}" class="edit-btn w-full px-3 py-2 bg-lapis-900 text-saffron-300 rounded-full text-xs font-semibold hover:bg-lapis-800 transition">
              ✎ Modifier
            </button>
          </div>
        </div>
      `,
      )
      .join('');
    productList.querySelectorAll<HTMLButtonElement>('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const p = products.find((x) => x.id === btn.dataset.id);
        if (p) {
          fillForm(p);
          showModal(true);
        }
      });
    });
  }

  async function resizeImage(file: File, maxSize: number, quality: number): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          let w = img.width;
          let h = img.height;
          const scale = Math.min(1, maxSize / Math.max(w, h));
          w = Math.round(w * scale);
          h = Math.round(h * scale);
          const canvas = document.createElement('canvas');
          canvas.width = w;
          canvas.height = h;
          const ctx = canvas.getContext('2d');
          if (!ctx) return reject(new Error('Canvas non disponible'));
          ctx.drawImage(img, 0, 0, w, h);
          resolve(canvas.toDataURL('image/jpeg', quality));
        };
        img.onerror = () => reject(new Error('Image illisible'));
        img.src = e.target?.result as string;
      };
      reader.onerror = () => reject(new Error('Lecture du fichier impossible'));
      reader.readAsDataURL(file);
    });
  }

  imageInput.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    formError.textContent = '';
    try {
      currentImage = await resizeImage(file, 1000, 0.78);
      imagePreview.src = currentImage;
      imagePreview.classList.remove('hidden');
    } catch (err) {
      formError.textContent = 'Image invalide : ' + (err as Error).message;
    }
  });

  document.getElementById('close-modal')!.addEventListener('click', () => {
    showModal(false);
    resetForm();
  });
  document.getElementById('cancel-btn')!.addEventListener('click', () => {
    showModal(false);
    resetForm();
  });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      showModal(false);
      resetForm();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      showModal(false);
      resetForm();
    }
  });

  // === Bootstrap Firebase ===
  const isConfigured = Boolean(config.apiKey && config.projectId);
  if (!isConfigured) {
    notConfigured.classList.remove('hidden');
  } else {
    app = initializeApp(config);
    auth = getAuth(app);
    db = getFirestore(app);

    onAuthStateChanged(auth, async (user) => {
      if (user) {
        // Vérifier le rôle admin avant de montrer l'interface
        try {
          const adminDoc = await getDoc(doc(db!, 'admins', user.uid));
          if (!adminDoc.exists()) {
            loginSection.classList.add('hidden');
            adminSection.classList.add('hidden');
            const notAdmin = document.getElementById('not-admin');
            if (notAdmin) notAdmin.classList.remove('hidden');
            return;
          }
        } catch {
          // En cas d'erreur de lecture, on bloque par sécurité
          loginSection.classList.add('hidden');
          adminSection.classList.add('hidden');
          const notAdmin = document.getElementById('not-admin');
          if (notAdmin) notAdmin.classList.remove('hidden');
          return;
        }
        document.getElementById('user-email')!.textContent = user.email || '(sans email)';
        loginSection.classList.add('hidden');
        adminSection.classList.remove('hidden');
        const notAdmin = document.getElementById('not-admin');
        if (notAdmin) notAdmin.classList.add('hidden');
        subscribeProducts();
      } else {
        loginSection.classList.remove('hidden');
        adminSection.classList.add('hidden');
        const notAdmin = document.getElementById('not-admin');
        if (notAdmin) notAdmin.classList.add('hidden');
        products = [];
      }
    });

    document.getElementById('login-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errEl = document.getElementById('login-error')!;
      errEl.textContent = '';
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      try {
        await signInWithEmailAndPassword(auth!, email, password);
      } catch (err) {
        errEl.textContent = 'Identifiants invalides.';
      }
    });

    document.getElementById('logout-btn')!.addEventListener('click', () => signOut(auth!));
    document.getElementById('not-admin-logout')?.addEventListener('click', () => signOut(auth!));

    document.getElementById('add-btn')!.addEventListener('click', () => {
      resetForm();
      showModal(true);
    });

    document.getElementById('seed-btn')!.addEventListener('click', async () => {
      if (!confirm(`Importer ${seedData.products.length} produits depuis products.json dans Firestore ?\n\nLes produits existants avec le même ID seront écrasés.`)) return;
      const btn = document.getElementById('seed-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Import en cours…';
      try {
        for (const p of seedData.products) {
          await setDoc(doc(db!, 'products', p.id), {
            slug: p.slug,
            name: p.name,
            category: p.category,
            description: p.description,
            shortDescription: p.shortDescription,
            priceCents: p.priceCents,
            currency: p.currency,
            unit: p.unit,
            image: p.image,
            stock: p.stock,
            createdAt: serverTimestamp(),
          });
        }
        alert('✓ Import terminé');
      } catch (err) {
        alert('Erreur import : ' + (err as Error).message);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Importer le seed';
      }
    });

    deleteBtn.addEventListener('click', async () => {
      if (!editingId || !db) return;
      if (!confirm('Supprimer ce produit définitivement ?')) return;
      try {
        await deleteDoc(doc(db, 'products', editingId));
        showModal(false);
        resetForm();
      } catch (err) {
        formError.textContent = 'Erreur : ' + (err as Error).message;
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      formError.textContent = '';
      if (!db) return;
      const priceFloat = parseFloat(fPrice.value);
      if (isNaN(priceFloat) || priceFloat < 0) {
        formError.textContent = 'Prix invalide.';
        return;
      }
      const slug = (fSlug.value.trim() || slugify(fName.value)).toLowerCase();
      if (!/^[a-z0-9-]+$/.test(slug)) {
        formError.textContent = 'Slug invalide (minuscules, chiffres, tirets).';
        return;
      }
      const data = {
        slug,
        name: fName.value.trim(),
        category: fCategory.value,
        description: fDesc.value.trim(),
        shortDescription: fShort.value.trim(),
        priceCents: Math.round(priceFloat * 100),
        currency: 'eur',
        unit: fUnit.value.trim(),
        image: currentImage,
        stock: parseInt(fStock.value, 10) || 0,
      };

      submitBtn.disabled = true;
      try {
        if (editingId) {
          await updateDoc(doc(db, 'products', editingId), data);
        } else {
          await addDoc(collection(db, 'products'), { ...data, createdAt: serverTimestamp() });
        }
        showModal(false);
        resetForm();
      } catch (err) {
        formError.textContent = 'Erreur : ' + (err as Error).message;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }

  function subscribeProducts() {
    if (!db) return;
    const q = query(collection(db, 'products'), orderBy('createdAt', 'desc'));
    onSnapshot(
      q,
      (snap) => {
        products = snap.docs.map((d) => ({ id: d.id, ...(d.data() as Omit<Product, 'id'>) }));
        renderProducts();
      },
      (err) => {
        productList.innerHTML = `<p class="col-span-full text-center text-pomegranate-700 py-8">Erreur de chargement : ${escapeHtml(err.message)}</p>`;
      },
    );
  }
</script>
