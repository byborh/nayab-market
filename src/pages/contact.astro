---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Contact — Nayab Market" description="Une question ? Contactez Nayab Market à Paris, ou venez nous voir au 4 place de la Chapelle.">
  <section class="py-12 px-4 sm:px-6 bg-gradient-to-br from-lapis-900 via-lapis-800 to-pomegranate-900 text-sand-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-kilim-pattern opacity-50"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-saffron-300 mb-2">Nous contacter</h1>
      <p class="font-accent text-lg text-sand-100 italic">Une question, une suggestion, un projet ? Écrivez-nous.</p>
    </div>
  </section>

  <section class="py-12 px-4 sm:px-6 bg-sand-50">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-[1fr,1.3fr] gap-10">
      <div class="space-y-6">
        <div class="bg-white border-l-4 border-saffron-500 rounded-lg p-5 shadow">
          <strong class="block text-pomegranate-700 mb-1 font-semibold">📍 Boutique</strong>
          4 place de la Chapelle<br />75018 Paris
        </div>
        <div class="bg-white border-l-4 border-saffron-500 rounded-lg p-5 shadow">
          <strong class="block text-pomegranate-700 mb-1 font-semibold">⏰ Horaires</strong>
          Lundi – Samedi : 9h – 21h<br />Dimanche : 10h – 20h
        </div>
        <div class="bg-white border-l-4 border-saffron-500 rounded-lg p-5 shadow">
          <strong class="block text-pomegranate-700 mb-1 font-semibold">🚇 Accès</strong>
          Métro La Chapelle (ligne 2) · Marx Dormoy (ligne 12)
        </div>
        <div class="bg-white border-l-4 border-saffron-500 rounded-lg p-5 shadow">
          <strong class="block text-pomegranate-700 mb-1 font-semibold">⏱️ Délai de réponse</strong>
          Nous répondons généralement sous 24 à 48 h ouvrées.
        </div>
      </div>

      <div class="bg-white rounded-2xl border-2 border-saffron-200 shadow-lg p-6 sm:p-8">
        <h2 class="font-display text-2xl text-lapis-900 mb-5">Envoyer un message</h2>
        <form id="contact-form" class="space-y-4">
          <input type="text" name="honeypot" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] w-px h-px" aria-hidden="true" />

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-lapis-900 mb-1" for="c-name">Nom *</label>
              <input type="text" id="c-name" name="name" required maxlength="100" class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-lapis-900 mb-1" for="c-email">Email *</label>
              <input type="email" id="c-email" name="email" required maxlength="200" class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1" for="c-subject">Sujet</label>
            <input type="text" id="c-subject" name="subject" maxlength="200" class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-lapis-900 mb-1" for="c-message">Message *</label>
            <textarea id="c-message" name="message" required rows="6" maxlength="5000" class="w-full px-4 py-2.5 border border-sand-300 rounded-lg bg-sand-50 focus:outline-none focus:border-saffron-400 focus:bg-white transition"></textarea>
          </div>

          <p id="contact-feedback" class="text-sm min-h-[1.25rem]"></p>

          <button type="submit" id="contact-submit" class="w-full px-6 py-3 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition-all disabled:opacity-60 disabled:cursor-not-allowed">
            Envoyer
          </button>
          <p class="text-xs text-lapis-500 text-center">En envoyant ce message, vous acceptez que vos données soient traitées conformément à notre <a href="/confidentialite" class="underline hover:text-pomegranate-700">politique de confidentialité</a>.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const feedback = document.getElementById('contact-feedback')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedback.textContent = '';
    feedback.className = 'text-sm min-h-[1.25rem]';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi…';

    const data = new FormData(form);
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          email: data.get('email'),
          subject: data.get('subject'),
          message: data.get('message'),
          honeypot: data.get('honeypot'),
        }),
      });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error || 'Erreur lors de l\'envoi.');
      feedback.textContent = '✓ Message envoyé. Nous revenons vers vous très vite.';
      feedback.className = 'text-sm min-h-[1.25rem] text-green-700';
      form.reset();
    } catch (err) {
      feedback.textContent = (err as Error).message;
      feedback.className = 'text-sm min-h-[1.25rem] text-pomegranate-700';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Envoyer';
    }
  });
</script>
