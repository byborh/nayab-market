---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Page introuvable — Nayab Market" description="Cette page n'existe pas ou a été déplacée.">
  <section class="py-24 px-4 sm:px-6 bg-gradient-to-br from-sand-50 to-sand-100 min-h-[70vh] flex items-center">
    <div class="max-w-xl mx-auto text-center">
      <p class="font-display text-8xl sm:text-9xl font-bold text-saffron-400/40 mb-4">404</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-lapis-900 mb-3">Page introuvable</h1>
      <p class="text-lapis-700 mb-8">
        Cette page n'existe pas, ou alors elle s'est perdue quelque part entre Paris et Kaboul.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 border-2 border-lapis-900 text-lapis-900 rounded-full font-semibold hover:bg-lapis-900 hover:text-saffron-300 transition-all">
          Retour à l'accueil
        </a>
        <a href="/boutique" class="px-6 py-3 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition">
          Voir la boutique →
        </a>
      </div>
    </div>
  </section>
</Layout>
