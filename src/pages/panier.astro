---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Panier — Nayab Market">
  <section class="py-16 px-4 sm:px-6 bg-gradient-to-br from-lapis-900 via-lapis-800 to-pomegranate-900 text-sand-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-kilim-pattern opacity-50"></div>
    <div class="relative z-10 max-w-7xl mx-auto text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-saffron-300">Mon Panier</h1>
    </div>
  </section>

  <section class="py-16 px-4 sm:px-6 bg-sand-50 min-h-[60vh]">
    <div class="max-w-5xl mx-auto">
      <div id="empty-cart" class="hidden text-center py-20">
        <div class="text-6xl mb-4">🛒</div>
        <h2 class="font-display text-2xl text-lapis-900 mb-3">Votre panier est vide</h2>
        <p class="text-lapis-700 mb-8">Découvrez notre sélection de produits afghans authentiques.</p>
        <a
          href="/boutique"
          class="inline-block px-8 py-3 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition"
        >
          Aller à la boutique →
        </a>
      </div>

      <div id="cart-content" class="hidden">
        <div id="cart-items" class="space-y-4 mb-8"></div>

        <div class="bg-white rounded-2xl p-6 sm:p-8 border-2 border-saffron-200 shadow-lg">
          <div class="flex justify-between items-baseline mb-2">
            <span class="text-lapis-700">Sous-total</span>
            <span id="subtotal" class="font-semibold text-lapis-900">0,00 €</span>
          </div>
          <div class="flex justify-between items-baseline mb-2">
            <span class="text-lapis-700">Livraison</span>
            <span class="text-lapis-900">Calculée au paiement</span>
          </div>
          <div class="border-t border-sand-200 my-4"></div>
          <div class="flex justify-between items-baseline mb-6">
            <span class="font-display text-2xl text-lapis-900">Total</span>
            <span id="total" class="font-accent text-3xl font-bold text-pomegranate-700">0,00 €</span>
          </div>

          <button
            id="checkout-btn"
            class="w-full px-6 py-4 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold text-lg hover:-translate-y-0.5 hover:shadow-xl hover:shadow-saffron-500/40 transition-all disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Procéder au paiement
          </button>
          <p class="text-center text-xs text-lapis-500 mt-3">🔒 Paiement sécurisé par Stripe</p>
          <p id="checkout-error" class="text-center text-pomegranate-700 text-sm mt-3"></p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  type CartItem = {
    id: string;
    name: string;
    priceCents: number;
    image: string;
    unit: string;
    qty: number;
  };

  function loadCart(): CartItem[] {
    try {
      return JSON.parse(localStorage.getItem('nayab-cart') || '[]');
    } catch {
      return [];
    }
  }
  function saveCart(cart: CartItem[]) {
    localStorage.setItem('nayab-cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('nayab-cart-updated'));
  }
  function formatPrice(cents: number) {
    return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(cents / 100);
  }
  function escapeHtml(s: string) {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function render() {
    const cart = loadCart();
    const empty = document.getElementById('empty-cart')!;
    const content = document.getElementById('cart-content')!;
    const itemsContainer = document.getElementById('cart-items')!;

    if (!cart.length) {
      empty.classList.remove('hidden');
      content.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    content.classList.remove('hidden');

    itemsContainer.innerHTML = cart
      .map(
        (i) => `
        <div class="bg-white rounded-2xl p-4 sm:p-5 border-2 border-saffron-200 shadow-md flex gap-4 items-center">
          <img src="${escapeHtml(i.image)}" alt="${escapeHtml(i.name)}" class="w-20 h-20 sm:w-24 sm:h-24 object-cover rounded-lg flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <h3 class="font-display text-base sm:text-lg font-semibold text-lapis-900 truncate">${escapeHtml(i.name)}</h3>
            <p class="text-sm text-lapis-600 mb-2">${formatPrice(i.priceCents)} / ${escapeHtml(i.unit)}</p>
            <div class="flex items-center gap-2">
              <button data-id="${escapeHtml(i.id)}" data-action="minus" class="qty-btn w-8 h-8 rounded-full border-2 border-saffron-300 text-lapis-900 font-bold hover:bg-saffron-100">−</button>
              <span class="w-8 text-center font-semibold">${i.qty}</span>
              <button data-id="${escapeHtml(i.id)}" data-action="plus" class="qty-btn w-8 h-8 rounded-full border-2 border-saffron-300 text-lapis-900 font-bold hover:bg-saffron-100">+</button>
              <button data-id="${escapeHtml(i.id)}" data-action="remove" class="ml-3 text-pomegranate-700 hover:text-pomegranate-900 text-sm font-semibold">Retirer</button>
            </div>
          </div>
          <div class="font-accent text-xl font-bold text-pomegranate-700 flex-shrink-0">${formatPrice(i.priceCents * i.qty)}</div>
        </div>
      `,
      )
      .join('');

    const subtotal = cart.reduce((s, i) => s + i.priceCents * i.qty, 0);
    document.getElementById('subtotal')!.textContent = formatPrice(subtotal);
    document.getElementById('total')!.textContent = formatPrice(subtotal);

    document.querySelectorAll<HTMLButtonElement>('.qty-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id!;
        const action = btn.dataset.action!;
        const cart = loadCart();
        const item = cart.find((i) => i.id === id);
        if (!item) return;
        if (action === 'plus') item.qty += 1;
        if (action === 'minus' && item.qty > 1) item.qty -= 1;
        if (action === 'remove' || (action === 'minus' && item.qty === 1)) {
          saveCart(cart.filter((i) => i.id !== id));
        } else {
          saveCart(cart);
        }
        render();
      });
    });
  }

  render();

  // === Auth token (optionnel : utilisé pour lier la commande à un compte) ===
  async function getAuthIdToken(): Promise<string | null> {
    const apiKey = import.meta.env.PUBLIC_FIREBASE_API_KEY;
    const projectId = import.meta.env.PUBLIC_FIREBASE_PROJECT_ID;
    if (!apiKey || !projectId) return null;
    try {
      const { initializeApp, getApps } = await import('firebase/app');
      const { getAuth } = await import('firebase/auth');
      const app = getApps().length ? getApps()[0] : initializeApp({
        apiKey,
        authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
        projectId,
        storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
        messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
        appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
      });
      const user = getAuth(app).currentUser;
      return user ? await user.getIdToken() : null;
    } catch {
      return null;
    }
  }

  document.getElementById('checkout-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const errEl = document.getElementById('checkout-error')!;
    errEl.textContent = '';
    const cart = loadCart();
    if (!cart.length) return;

    btn.disabled = true;
    btn.textContent = 'Redirection vers le paiement…';
    try {
      const idToken = await getAuthIdToken();
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(idToken ? { Authorization: `Bearer ${idToken}` } : {}),
        },
        body: JSON.stringify({
          items: cart.map((i) => ({ id: i.id, qty: i.qty })),
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.url) {
        throw new Error(data.error || 'Erreur lors de la création de la session de paiement.');
      }
      window.location.href = data.url;
    } catch (err) {
      errEl.textContent = (err as Error).message;
      btn.disabled = false;
      btn.textContent = 'Procéder au paiement';
    }
  });
</script>
