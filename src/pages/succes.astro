---
import Layout from '~/layouts/Layout.astro';
import Stripe from 'stripe';

export const prerender = false;

const sessionId = Astro.url.searchParams.get('session_id');

type Receipt = {
  id: string;
  shortRef: string;
  status: string;
  email: string;
  name?: string;
  items: Array<{ name: string; qty: number; amount: number; currency: string }>;
  subtotal: number;
  shipping: number;
  total: number;
  currency: string;
  shippingMethod?: string;
  address?: Array<string>;
};

let receipt: Receipt | null = null;
let error: string | null = null;

if (sessionId) {
  const secret = import.meta.env.STRIPE_SECRET_KEY;
  if (!secret) {
    error = 'Stripe non configuré (STRIPE_SECRET_KEY).';
  } else {
    try {
      const stripe = new Stripe(secret, { apiVersion: '2024-12-18.acacia' });
      const session = await stripe.checkout.sessions.retrieve(sessionId, {
        expand: ['line_items', 'shipping_cost.shipping_rate'],
      });

      if (session.payment_status === 'paid') {
        const items = (session.line_items?.data || []).map((li) => ({
          name: li.description || 'Produit',
          qty: li.quantity || 1,
          amount: li.amount_subtotal || 0,
          currency: (li.currency || session.currency || 'eur').toLowerCase(),
        }));

        const subtotal = session.amount_subtotal ?? items.reduce((s, i) => s + i.amount, 0);
        const total = session.amount_total ?? subtotal;
        const shipping = total - subtotal;
        const sr = session.shipping_cost?.shipping_rate;
        const shippingMethod =
          sr && typeof sr !== 'string' ? sr.display_name || undefined : undefined;
        const addr = session.shipping_details?.address;
        const addressLines = addr
          ? [
              session.shipping_details?.name,
              addr.line1,
              addr.line2,
              [addr.postal_code, addr.city].filter(Boolean).join(' '),
              addr.country,
            ].filter((s): s is string => Boolean(s))
          : undefined;

        receipt = {
          id: session.id,
          shortRef: session.id.slice(-12).toUpperCase(),
          status: 'paid',
          email: session.customer_details?.email || session.customer_email || '',
          name: session.customer_details?.name || undefined,
          items,
          subtotal,
          shipping,
          total,
          currency: (session.currency || 'eur').toLowerCase(),
          shippingMethod,
          address: addressLines,
        };
      } else {
        error = 'Paiement non confirmé. Si tu viens de payer, recharge la page dans quelques secondes.';
      }
    } catch (err) {
      error = err instanceof Error ? err.message : 'Erreur lors de la récupération du paiement.';
    }
  }
} else {
  error = 'Aucun identifiant de session dans l\'URL.';
}

function fmt(cents: number, currency = 'EUR'): string {
  return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: currency.toUpperCase() }).format(cents / 100);
}
---

<Layout title={receipt ? `Commande ${receipt.shortRef} — Nayab Market` : 'Commande confirmée — Nayab Market'} noindex={true}>
  <section class="py-16 px-4 sm:px-6 bg-gradient-to-br from-sand-50 to-sand-100 min-h-[70vh]">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-lapis-900 mb-3">Merci pour votre commande !</h1>
        <p class="text-lapis-700">Votre paiement a bien été confirmé. Un email de confirmation vient d'être envoyé.</p>
      </div>

      {error && (
        <div class="bg-pomegranate-50 border-l-4 border-pomegranate-600 rounded-lg p-5 mb-8">
          <p class="text-pomegranate-700">{error}</p>
        </div>
      )}

      {receipt && (
        <div class="bg-white rounded-2xl border-2 border-saffron-200 shadow-xl overflow-hidden">
          <div class="bg-lapis-900 text-saffron-300 px-6 sm:px-8 py-4 flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <div class="text-xs uppercase tracking-widest text-sand-200">Référence</div>
              <div class="font-mono font-bold text-lg">#{receipt.shortRef}</div>
            </div>
            <div class="text-right">
              <div class="text-xs uppercase tracking-widest text-sand-200">Statut</div>
              <div class="font-semibold">✓ Payée</div>
            </div>
          </div>

          <div class="p-6 sm:p-8">
            <h2 class="font-display text-xl text-lapis-900 mb-4">Articles</h2>
            <div class="space-y-3 mb-6">
              {receipt.items.map((i) => (
                <div class="flex justify-between items-baseline pb-3 border-b border-sand-200">
                  <div>
                    <div class="font-semibold text-lapis-900">{i.name}</div>
                    <div class="text-sm text-lapis-600">Quantité : {i.qty}</div>
                  </div>
                  <div class="font-accent text-lg font-bold text-pomegranate-700">{fmt(i.amount, i.currency)}</div>
                </div>
              ))}
            </div>

            <div class="space-y-1 mb-4 text-sm">
              <div class="flex justify-between"><span class="text-lapis-600">Sous-total</span><span class="text-lapis-900">{fmt(receipt.subtotal, receipt.currency)}</span></div>
              <div class="flex justify-between"><span class="text-lapis-600">Livraison{receipt.shippingMethod ? ` (${receipt.shippingMethod})` : ''}</span><span class="text-lapis-900">{fmt(receipt.shipping, receipt.currency)}</span></div>
            </div>
            <div class="flex justify-between items-baseline pt-3 border-t-2 border-lapis-900">
              <span class="font-display text-2xl text-lapis-900">Total</span>
              <span class="font-accent text-3xl font-bold text-pomegranate-700">{fmt(receipt.total, receipt.currency)}</span>
            </div>

            {receipt.address && receipt.address.length > 0 && (
              <div class="mt-8">
                <h2 class="font-display text-xl text-lapis-900 mb-3">Livraison</h2>
                <div class="bg-sand-50 rounded-lg p-4 text-lapis-800 leading-relaxed">
                  {receipt.address.map((line) => <div>{line}</div>)}
                </div>
              </div>
            )}

            <div class="mt-8 text-sm text-lapis-600">
              Un récapitulatif a été envoyé à <strong class="text-lapis-900">{receipt.email}</strong>.
              Tu peux à tout moment suivre cette commande via le lien envoyé par email.
            </div>
          </div>
        </div>
      )}

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a href="/" class="text-center px-6 py-3 border-2 border-lapis-900 text-lapis-900 rounded-full font-semibold hover:bg-lapis-900 hover:text-saffron-300 transition-all">
          Retour à l'accueil
        </a>
        <a href="/boutique" class="text-center px-6 py-3 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition">
          Continuer mes achats →
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Vider le panier après paiement réussi
  localStorage.removeItem('nayab-cart');
  window.dispatchEvent(new Event('nayab-cart-updated'));
</script>
