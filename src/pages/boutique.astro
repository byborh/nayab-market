---
import Layout from '~/layouts/Layout.astro';
import { getProducts, categories, formatPrice } from '~/lib/products';

export const prerender = false;

const activeCat = Astro.url.searchParams.get('cat') ?? 'all';
const allProducts = await getProducts();
const filtered = activeCat === 'all' ? allProducts : allProducts.filter((p) => p.category === activeCat);
---

<Layout title="Boutique — Nayab Market" description="Découvrez notre sélection de produits afghans : fruits secs, épices, thés, riz basmati et plus.">
  <section class="py-16 px-4 sm:px-6 bg-gradient-to-br from-lapis-900 via-lapis-800 to-pomegranate-900 text-sand-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-kilim-pattern opacity-50"></div>
    <div class="relative z-10 max-w-7xl mx-auto text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-saffron-300 mb-3">Notre Boutique</h1>
      <p class="font-accent text-xl text-sand-100 italic">Les saveurs afghanes livrées chez vous</p>
    </div>
  </section>

  <section class="py-12 px-4 sm:px-6 bg-sand-50">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
        <a
          href="/boutique"
          class={`px-5 py-2 rounded-full text-sm font-semibold transition-all ${
            activeCat === 'all'
              ? 'bg-lapis-900 text-saffron-300'
              : 'bg-white text-lapis-900 border border-saffron-300 hover:bg-saffron-100'
          }`}
        >
          Tous
        </a>
        {
          categories.map((cat) => (
            <a
              href={`/boutique?cat=${cat.id}`}
              class={`px-5 py-2 rounded-full text-sm font-semibold transition-all ${
                activeCat === cat.id
                  ? 'bg-lapis-900 text-saffron-300'
                  : 'bg-white text-lapis-900 border border-saffron-300 hover:bg-saffron-100'
              }`}
            >
              {cat.emoji} {cat.name}
            </a>
          ))
        }
      </div>

      <div class="mb-6 max-w-md mx-auto">
        <input
          type="search"
          id="search-input"
          placeholder="Rechercher un produit…"
          aria-label="Rechercher un produit"
          class="w-full px-5 py-3 border-2 border-saffron-200 rounded-full bg-white text-lapis-900 placeholder:text-lapis-400 focus:outline-none focus:border-saffron-400 transition"
        />
      </div>

      <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {
          filtered.map((p) => {
            const inStock = (p.stock ?? 0) > 0;
            return (
              <div
                class="product-card group bg-white rounded-2xl overflow-hidden border-2 border-saffron-200 shadow-lg shadow-pomegranate-900/5 hover:-translate-y-2 hover:shadow-2xl hover:shadow-saffron-500/20 hover:border-saffron-400 transition-all flex flex-col"
                data-name={p.name.toLowerCase()}
                data-desc={p.shortDescription.toLowerCase()}
              >
                <a href={`/produit/${p.slug}`} class="block relative aspect-square overflow-hidden bg-sand-100">
                  <img
                    src={p.image}
                    alt={p.name}
                    loading="lazy"
                    class={`w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ${!inStock ? 'opacity-60' : ''}`}
                  />
                  {!inStock && (
                    <div class="absolute top-3 left-3 bg-pomegranate-700 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full shadow-lg">
                      Épuisé
                    </div>
                  )}
                </a>
                <div class="p-5 flex flex-col flex-1">
                  <a href={`/produit/${p.slug}`} class="font-display text-lg font-semibold text-lapis-900 mb-1 hover:text-pomegranate-700 transition">{p.name}</a>
                  <p class="text-xs text-lapis-600 mb-3 line-clamp-2 flex-1">{p.shortDescription}</p>
                  <div class="flex items-baseline justify-between mb-3">
                    <span class="font-accent text-2xl font-bold text-pomegranate-700">{formatPrice(p.priceCents, p.currency)}</span>
                    <span class="text-xs text-lapis-500">/ {p.unit}</span>
                  </div>
                  {inStock ? (
                    <button
                      class="add-to-cart-btn w-full px-4 py-2.5 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold text-sm hover:-translate-y-0.5 hover:shadow-lg hover:shadow-saffron-500/40 transition-all"
                      data-id={p.id}
                      data-name={p.name}
                      data-price={p.priceCents}
                      data-image={p.image}
                      data-unit={p.unit}
                    >
                      + Ajouter au panier
                    </button>
                  ) : (
                    <button
                      disabled
                      class="w-full px-4 py-2.5 bg-sand-200 text-lapis-500 rounded-full font-semibold text-sm cursor-not-allowed"
                    >
                      Indisponible
                    </button>
                  )}
                </div>
              </div>
            );
          })
        }
      </div>

      <p id="no-results" class="hidden text-center text-lapis-600 italic py-12">Aucun produit ne correspond à ta recherche.</p>
    </div>
  </section>

  <div
    id="toast"
    class="fixed bottom-6 right-6 z-50 bg-lapis-900 text-saffron-300 px-5 py-3 rounded-lg shadow-2xl border border-saffron-400/30 opacity-0 translate-y-4 transition-all pointer-events-none"
  >
    ✓ Ajouté au panier
  </div>
</Layout>

<script>
  type CartItem = {
    id: string;
    name: string;
    priceCents: number;
    image: string;
    unit: string;
    qty: number;
  };

  function loadCart(): CartItem[] {
    try {
      const raw = localStorage.getItem('nayab-cart');
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function saveCart(cart: CartItem[]) {
    localStorage.setItem('nayab-cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('nayab-cart-updated'));
  }

  function showToast() {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.style.opacity = '1';
    toast.style.transform = 'translateY(0)';
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(1rem)';
    }, 1800);
  }

  document.querySelectorAll<HTMLButtonElement>('.add-to-cart-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id!;
      const cart = loadCart();
      const existing = cart.find((i) => i.id === id);
      if (existing) {
        existing.qty += 1;
      } else {
        cart.push({
          id,
          name: btn.dataset.name!,
          priceCents: Number(btn.dataset.price),
          image: btn.dataset.image!,
          unit: btn.dataset.unit!,
          qty: 1,
        });
      }
      saveCart(cart);
      showToast();
    });
  });

  // Search filter
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const noResults = document.getElementById('no-results');
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.trim().toLowerCase();
      let visible = 0;
      document.querySelectorAll<HTMLDivElement>('.product-card').forEach((card) => {
        const name = card.dataset.name || '';
        const desc = card.dataset.desc || '';
        const match = !q || name.includes(q) || desc.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    });
  }
</script>
