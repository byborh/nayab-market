---
import { getProducts, formatPrice } from '~/lib/products';
const all = await getProducts();
const featured = all.slice(0, 4);
---

<section class="py-24 px-4 sm:px-6 bg-gradient-to-br from-sand-50 to-sand-100" id="featured">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-display text-4xl sm:text-5xl font-bold text-center text-lapis-900 mb-4">
      Best-sellers
    </h2>
    <div class="w-24 h-0.5 bg-gradient-to-r from-transparent via-saffron-500 to-transparent mx-auto mb-12"></div>
    <p class="text-center text-lapis-700 max-w-2xl mx-auto mb-12">
      Nos produits les plus appréciés, sélectionnés avec soin et livrés partout en France.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        featured.map((p) => (
          <a
            href={`/produit/${p.slug}`}
            class="group bg-white rounded-2xl overflow-hidden border-2 border-saffron-200 shadow-lg shadow-pomegranate-900/5 hover:-translate-y-2 hover:shadow-2xl hover:shadow-saffron-500/20 hover:border-saffron-400 transition-all"
          >
            <div class="relative aspect-square overflow-hidden bg-sand-100">
              <img
                src={p.image}
                alt={p.name}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-5">
              <h3 class="font-display text-lg font-semibold text-lapis-900 mb-1 line-clamp-1">{p.name}</h3>
              <p class="text-xs text-lapis-600 mb-3 line-clamp-2">{p.shortDescription}</p>
              <div class="flex items-baseline justify-between">
                <span class="font-accent text-2xl font-bold text-pomegranate-700">{formatPrice(p.priceCents, p.currency)}</span>
                <span class="text-xs text-lapis-500">/ {p.unit}</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="text-center mt-12">
      <a
        href="/boutique"
        class="inline-block px-8 py-4 bg-gradient-to-br from-saffron-400 to-saffron-500 text-lapis-900 rounded-full font-semibold hover:-translate-y-1 hover:shadow-xl hover:shadow-saffron-500/40 transition-all"
      >
        Voir toute la boutique →
      </a>
    </div>
  </div>
</section>
