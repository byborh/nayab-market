---
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const navLinks = isHome
  ? [
      { href: '#about', label: 'À Propos' },
      { href: '#categories', label: 'Catégories' },
      { href: '/boutique', label: 'Boutique' },
      { href: '/faq', label: 'FAQ' },
      { href: '/contact', label: 'Contact' },
    ]
  : [
      { href: '/', label: 'Accueil' },
      { href: '/boutique', label: 'Boutique' },
      { href: '/faq', label: 'FAQ' },
      { href: '/contact', label: 'Contact' },
    ];
---

<header
  class="fixed top-0 inset-x-0 z-50 bg-lapis-900/95 backdrop-blur-md border-b border-saffron-400/30"
>
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-4 sm:px-6 py-4">
    <a href="/" class="font-display text-xl sm:text-2xl font-bold text-saffron-300 tracking-widest hover:opacity-80 transition">
      ✦ Nayab Market
    </a>

    <ul class="hidden lg:flex items-center gap-8 list-none">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sand-50 text-sm font-medium tracking-wide relative hover:text-saffron-300 transition after:content-[''] after:absolute after:-bottom-1.5 after:left-0 after:w-0 after:h-0.5 after:bg-saffron-400 after:transition-all hover:after:w-full"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2 sm:gap-3">
      <!-- Compte (état connecté) -->
      <a
        href="/compte"
        id="account-link"
        class="hidden items-center gap-2 text-sand-50 hover:text-saffron-300 transition px-3 py-2"
        aria-label="Mon compte"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span id="account-name" class="hidden sm:inline text-sm font-medium max-w-[120px] truncate">Mon compte</span>
      </a>

      <!-- Connexion (état déconnecté) -->
      <a
        href="/connexion"
        id="login-link"
        class="hidden items-center gap-2 text-sand-50 hover:text-saffron-300 transition px-3 py-2 text-sm font-medium"
        aria-label="Connexion"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
          <polyline points="10 17 15 12 10 7"></polyline>
          <line x1="15" y1="12" x2="3" y2="12"></line>
        </svg>
        <span class="hidden sm:inline">Connexion</span>
      </a>

      <a
        href="/panier"
        id="cart-link"
        class="relative flex items-center gap-2 text-sand-50 hover:text-saffron-300 transition px-3 py-2"
        aria-label="Panier"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span
          id="cart-count"
          class="absolute -top-1 -right-1 bg-pomegranate-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center opacity-0 transition-opacity"
        >0</span>
      </a>
    </div>
  </nav>
</header>

<div class="h-[72px]"></div>

<script>
  // === Cart badge ===
  function updateCartBadge() {
    try {
      const raw = localStorage.getItem('nayab-cart');
      const cart = raw ? JSON.parse(raw) : [];
      const count = cart.reduce((sum: number, i: { qty: number }) => sum + (i.qty || 0), 0);
      const badge = document.getElementById('cart-count');
      if (!badge) return;
      badge.textContent = String(count);
      badge.style.opacity = count > 0 ? '1' : '0';
    } catch {}
  }
  updateCartBadge();
  window.addEventListener('storage', updateCartBadge);
  window.addEventListener('nayab-cart-updated', updateCartBadge);

  // === Auth state ===
  (async () => {
    const apiKey = import.meta.env.PUBLIC_FIREBASE_API_KEY;
    const projectId = import.meta.env.PUBLIC_FIREBASE_PROJECT_ID;
    const loginLink = document.getElementById('login-link');
    const accountLink = document.getElementById('account-link');
    if (!apiKey || !projectId) {
      // Pas de Firebase config : on cache les deux liens
      return;
    }
    const { initializeApp, getApps } = await import('firebase/app');
    const { getAuth, onAuthStateChanged } = await import('firebase/auth');
    const app = getApps().length ? getApps()[0] : initializeApp({
      apiKey,
      authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
      projectId,
      storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
      messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
      appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
    });
    const auth = getAuth(app);
    onAuthStateChanged(auth, (user) => {
      if (user) {
        accountLink?.classList.add('flex');
        accountLink?.classList.remove('hidden');
        loginLink?.classList.add('hidden');
        loginLink?.classList.remove('flex');
        const nameEl = document.getElementById('account-name');
        if (nameEl) nameEl.textContent = user.displayName || user.email || 'Mon compte';
      } else {
        loginLink?.classList.add('flex');
        loginLink?.classList.remove('hidden');
        accountLink?.classList.add('hidden');
        accountLink?.classList.remove('flex');
      }
    });
  })();
</script>
